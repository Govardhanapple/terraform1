resource "azurerm_resource_group" "apple" {
  name     = "sai"
  location = "West US"
}

resource "azurerm_virtual_network" "vnet" {
  name                = "vnet"
  resource_group_name = azurerm_resource_group.apple.name
  location            = azurerm_resource_group.apple.location
  address_space       = ["10.100.0.0/24"]
}

resource "azurerm_storage_account" "SVC" {
  name                            = "svc0000675"
  resource_group_name             = azurerm_resource_group.apple.name
  location                        = azurerm_resource_group.apple.location
  account_tier                    = "Standard"
  account_replication_type        = "LRS"
  allow_nested_items_to_be_public = true

  depends_on = [azurerm_resource_group.apple]
}

resource "azurerm_storage_container" "storage_container" {
  name                  = "stgcontainer"
  storage_account_name  = azurerm_storage_account.SVC.name
  container_access_type = "blob"

  depends_on = [azurerm_storage_account.SVC]
}

resource "azurerm_storage_blob" "container_file" {
  name                   = "sample.txt"
  storage_account_name   = azurerm_storage_account.SVC.name
  storage_container_name = azurerm_storage_container.storage_container.name
  type                   = "Block"
  source                 = "sample.txt"

  depends_on = [azurerm_storage_container.storage_container]
}

