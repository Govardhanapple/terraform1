# Resource Group
resource "azurerm_resource_group" "manforce" {
  name     = "rg-manforc"
  location = "West Europe"
}

# Virtual Network
resource "azurerm_virtual_network" "manforce_net" {
  name                = "manforce-network"
  location            = azurerm_resource_group.manforce.location
  resource_group_name = azurerm_resource_group.manforce.name
  address_space       = ["10.0.0.0/16"]
}

# Subnet
resource "azurerm_subnet" "manforce_subnet" {
  name                 = "subnet-1"
  resource_group_name  = azurerm_resource_group.manforce.name
  virtual_network_name = azurerm_virtual_network.manforce_net.name
  address_prefixes     = ["10.0.1.0/24"]
}

# Public IPs
resource "azurerm_public_ip" "man_pubip" {
  count               = 2
  name                = "app-pubip-${count.index + 1}"
  resource_group_name = azurerm_resource_group.manforce.name
  location            = azurerm_resource_group.manforce.location
  allocation_method   = "Static"
}

# Network Interfaces
resource "azurerm_network_interface" "man_nic" {
  count               = 2
  name                = "app-nic-${count.index + 1}"
  location            = azurerm_resource_group.manforce.location
  resource_group_name = azurerm_resource_group.manforce.name

  ip_configuration {
    name                          = "internal"
    subnet_id                     = azurerm_subnet.manforce_subnet.id
    private_ip_address_allocation = "Dynamic"
    public_ip_address_id          = azurerm_public_ip.man_pubip[count.index].id
  }
}

# Linux Virtual Machines
resource "azurerm_linux_virtual_machine" "man_vm" {
  count                 = 2
  name                  = "appservers-${count.index + 1}"
  resource_group_name   = azurerm_resource_group.manforce.name
  location              = azurerm_resource_group.manforce.location
  size                  = "Standard_D2s_v3"
  admin_username        = "adminuser"
  network_interface_ids = [azurerm_network_interface.man_nic[count.index].id]

  admin_ssh_key {
    username   = "adminuser"
    public_key = file("${path.module}/id_rsa.pub")
  }

  os_disk {
    caching              = "ReadWrite"
    storage_account_type = "Standard_LRS"
  }

  source_image_reference {
    publisher = "Canonical"
    offer     = "0001-com-ubuntu-server-jammy"
    sku       = "22_04-lts"
    version   = "latest"
  }
}

# Network Security Group
resource "azurerm_network_security_group" "man_nsg" {
  name                = "acceptanceTestSecurityGroup1"
  location            = azurerm_resource_group.manforce.location
  resource_group_name = azurerm_resource_group.manforce.name

  security_rule {
    name                       = "ssh-allow"
    priority                   = 100
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_range     = "22"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
}

# Associate NSG with Subnet
resource "azurerm_subnet_network_security_group_association" "man_assoc" {
  subnet_id                 = azurerm_subnet.manforce_subnet.id
  network_security_group_id = azurerm_network_security_group.man_nsg.id
}

# Storage Accounts
resource "azurerm_storage_account" "svctest" {
  count                           = 2
  name                            = "svctest${count.index + 1}"
  resource_group_name             = azurerm_resource_group.manforce.name
  location                        = azurerm_resource_group.manforce.location
  account_tier                    = "Standard"
  account_replication_type        = "LRS"
  allow_nested_items_to_be_public = true

  depends_on = [azurerm_resource_group.manforce]
}

# Storage Containers
resource "azurerm_storage_container" "con1" {
  count                 = 2
  name                  = "svc-cont-${count.index + 1}"
  storage_account_name  = azurerm_storage_account.svctest[count.index].name
  container_access_type = "blob"

  depends_on = [azurerm_storage_account.svctest]
}

# Storage Blobs
resource "azurerm_storage_blob" "containerfile" {
  count                  = 2
  name                   = "apple-${count.index + 1}.txt"
  storage_account_name   = azurerm_storage_account.svctest[count.index].name
  storage_container_name = azurerm_storage_container.con1[count.index].name
  type                   = "Block"
  source                 = "sample.txt"

  depends_on = [azurerm_storage_container.con1]
}
