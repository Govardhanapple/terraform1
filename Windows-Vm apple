
resource "azurerm_resource_group" "win_rg" {
  name     = "win-RG1"
  location = "Central US"
}

resource "azurerm_virtual_network" "win_network" {
  name                = "win-vent"
  location            = azurerm_resource_group.win_rg.location
  resource_group_name = azurerm_resource_group.win_rg.name
  address_space       = ["10.0.0.0/16"]
}

resource "azurerm_subnet" "win_subnet" {
  name                 = "win-subnet1"
  resource_group_name  = azurerm_resource_group.win_rg.name
  virtual_network_name = azurerm_virtual_network.win_network.name
  address_prefixes     = ["10.0.1.0/24"]
  depends_on           = [azurerm_virtual_network.win_network]
}

resource "azurerm_public_ip" "win_ip" {
  name                = "win-PublicIp1"
  resource_group_name = azurerm_resource_group.win_rg.name
  location            = azurerm_resource_group.win_rg.location
  allocation_method   = "Static"
  depends_on          = [azurerm_resource_group.win_rg]
}

resource "azurerm_network_interface" "win_nic" {
  name                = "win-nic"
  location            = azurerm_resource_group.win_rg.location
  resource_group_name = azurerm_resource_group.win_rg.name

  ip_configuration {
    name                          = "internal"
    subnet_id                     = azurerm_subnet.win_subnet.id
    private_ip_address_allocation = "Dynamic"
    public_ip_address_id          = azurerm_public_ip.win_ip.id
  }
  depends_on = [azurerm_subnet.win_subnet, azurerm_virtual_network.win_network, azurerm_public_ip.win_ip]
}

resource "azurerm_network_security_group" "nsg" {
  name                = "win-NSG"
  location            = azurerm_resource_group.win_rg.location
  resource_group_name = azurerm_resource_group.win_rg.name

  security_rule {
    name                       = "test123"
    priority                   = 100
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_range     = "3389"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }

  security_rule {
    name                       = "test124"
    priority                   = 101
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_range     = "80"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
}

resource "azurerm_subnet_network_security_group_association" "nsg_sub_association" {
  subnet_id                 = azurerm_subnet.win_subnet.id
  network_security_group_id = azurerm_network_security_group.nsg.id
  depends_on                = [azurerm_network_security_group.nsg]
}

resource "azurerm_windows_virtual_machine" "win_vm" {
  name                = "windows-machine"
  resource_group_name = azurerm_resource_group.win_rg.name
  location            = azurerm_resource_group.win_rg.location
  size                = "Standard_D2s_v3"
  admin_username      = "adminuser"
  admin_password      = "P@$$w0rd1234!"
  network_interface_ids = [
    azurerm_network_interface.win_nic.id
  ]
  depends_on = [azurerm_network_interface.win_nic]

  os_disk {
    caching              = "ReadWrite"
    storage_account_type = "Standard_LRS"
  }

  source_image_reference {
    publisher = "MicrosoftWindowsServer"
    offer     = "WindowsServer"
    sku       = "2019-Datacenter"
    version   = "latest"
  }

}

resource "azurerm_managed_disk" "Datadisk-1" {
  name                 = "datadisk"
  location             = azurerm_resource_group.win_rg.location
  resource_group_name  = azurerm_resource_group.win_rg.name
  storage_account_type = "Standard_LRS"
  create_option        = "Empty"
  disk_size_gb         = "5"
}
resource "azurerm_virtual_machine_data_disk_attachment" "attached1" {
  managed_disk_id    = azurerm_managed_disk.Datadisk-1.id
  virtual_machine_id = azurerm_windows_virtual_machine.win_vm.id
  lun                = "10"
  caching            = "ReadWrite"
  depends_on         = [azurerm_managed_disk.Datadisk-1, azurerm_windows_virtual_machine.win_vm]
}


resource "azurerm_storage_account" "svc" {
  name                            = "svc0000675857"
  resource_group_name             = azurerm_resource_group.win_rg.name
  location                        = azurerm_resource_group.win_rg.location
  account_tier                    = "Standard"
  account_replication_type        = "LRS"
  allow_nested_items_to_be_public = true

  depends_on = [azurerm_resource_group.win_rg]
}

resource "azurerm_storage_container" "storage_container" {
  name                  = "stgcontainer"
  storage_account_name  = azurerm_storage_account.svc.name
  container_access_type = "blob"

  depends_on = [azurerm_storage_account.svc]
}

resource "azurerm_storage_blob" "container_file" {
  name                   = "IIS_Config.ps1"
  storage_account_name   = azurerm_storage_account.svc.name
  storage_container_name = azurerm_storage_container.storage_container.name
  type                   = "Block"
  source                 = "IIS_Config.ps1"
  depends_on             = [azurerm_storage_container.storage_container]
}
resource "azurerm_virtual_machine_extension" "vm-extenction" {
  name                 = "applehost"
  virtual_machine_id   = azurerm_windows_virtual_machine.win_vm.id
  publisher            = "Microsoft.Compute"
  type                 = "CustomScriptExtension"
  type_handler_version = "1.10"
  depends_on           = [azurerm_storage_blob.container_file]
  settings             = <<SETTINGS
    {
        "fileUris": ["https://${azurerm_storage_account.svc.name}.blob.core.windows.net/stgcontainer/IIS_Config.ps1"],
          "commandToExecute": "powershell -ExecutionPolicy Unrestricted -file IIS_Config.ps1"     
    }
SETTINGS
}


